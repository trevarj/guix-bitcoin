;; -*- scheme -*-
(channel
 (version 0)
 (directory ".")
 (news-file "news.txt")
 ;; nonguix provides (nonguix build-system binary), used to repackage
 ;; Sparrow's upstream release image (see bitcoin/packages/wallets.scm).
 ;; Pulled transitively by consumers; authenticated via its introduction.
 (dependencies
  (channel
   (name nonguix)
   (url "https://gitlab.com/nonguix/nonguix")
   (branch "master")
   (introduction
    (channel-introduction
     (version 0)
     (commit "897c1a470da759236cc11798f4e0a5f7d4d59fbc")
     (signer "2A39 3FFF 68F4 EF7A 3D29  12AF 6F51 20A0 22FB B2D5"))))))
